{
  "manifest_version": 3,
  "name": "VIBE SHIFT: Sidebar Links",
  "version": "1.0",
  "author": "VIBE SHIFT LLC",
  "description": "The ultimate Vibe Coding sidebar. Access your links, snippets, and master templates in one click. Created by Andrew Domonkos.",
  "homepage_url": "https://kamikazeearth.blogspot.com/",
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "images/logo-16.png",
    "32": "images/logo-32.png",
    "48": "images/logo-48.png",
    "128": "images/logo-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "VIBE SHIFT",
    "default_icon": {
      "16": "images/logo-16.png",
      "32": "images/logo-32.png",
      "48": "images/logo-48.png",
      "128": "images/logo-128.png"
    }
  }
}